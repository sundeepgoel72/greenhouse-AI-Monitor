[Unit]
Description=Greenhouse AI Monitor backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__REPO_DIR__/backend
ExecStart=__REPO_DIR__/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8088
Restart=always
RestartSec=5
User=root
Group=root

[Install]
WantedBy=multi-user.target
